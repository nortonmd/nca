<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Account_for_Submission</fullName>
    <active>true</active>
    <errorConditionFormula>ISPICKVAL(Status__c, &apos;In Progress&apos;) &amp;&amp; ISBLANK(Account__c)</errorConditionFormula>
    <errorMessage>An Account must be associated with the RFP before it can be moved to In Progress.</errorMessage>
</ValidationRule>
