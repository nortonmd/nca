<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <classAccesses>
        <apexClass>SafetyConcernController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <description>Grants airline personnel portal users the ability to submit and view their own Safety Concern cases via the Experience Cloud portal.</description>
    <!-- Required fields (Incident_Date_Time__c, Incident_Type__c, Incident_Location__c,
         Severity__c, Personnel_Role__c) are omitted — Salesforce auto-grants FLS
         on required fields to all users with object access. -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Case.Airline_Flight_Number__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Case.Witnesses__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Safety Portal User</label>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Case</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
</PermissionSet>
